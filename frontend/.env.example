# Supabase (frontend). Leave blank to run unauthenticated demo mode.
# anon/publishable key is safe to expose to the browser; never put the service-role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional frontend error tracking (loaded only when set).
VITE_SENTRY_DSN=

# Optional product analytics (PostHog). Loaded only when VITE_POSTHOG_KEY is set. The key is the
# public project API key (safe to expose). HOST is the region host.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com
