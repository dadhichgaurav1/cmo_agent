# Models
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Pioneer inference gateway (primary LLM backend; native keys above are the fallback).
# Leave PIONEER_API_KEY blank to disable and use Anthropic/OpenAI directly.
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai

# Web research
EXA_API_KEY=

# Tool connectors
COMPOSIO_API_KEY=

# Maximem Synap memory (leave blank to use local JSON fallback)
SYNAP_API_KEY=
SYNAP_BASE_URL=

# Browser automation (stretch)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Supabase: auth + accounts/runs/monitors DB. Leave blank for single-tenant local/demo mode.
# Dashboard variable names are accepted as aliases (e.g. SUPABASE_PROJECT_URL, *_SECRET).
SUPABASE_URL=                      # or SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=         # or SUPABASE_SERVICE_ROLE_SECRET / SUPABASE_SECRET_KEY (bypasses RLS — server only)
SUPABASE_JWT_SECRET=               # or SUPABASE_LEGACY_JWT_SECRET (asymmetric tokens verified via JWKS instead)

# Redis / Arq worker. Set on both web + worker to run scheduled monitors off the web process.
REDIS_URL=

# Stripe billing. Leave blank to keep everyone on the free plan (billing endpoints report 503).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=             # from `stripe listen` (dev) or the dashboard webhook endpoint
STRIPE_PRICE_PRO=                  # recurring price id for the Pro plan
APP_BASE_URL=http://localhost:5173 # public app URL for Stripe success/cancel/return redirects
